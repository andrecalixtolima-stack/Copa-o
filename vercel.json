{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/reservations/create",
      "destination": "/api/reservations/create"
    },
    {
      "source": "/api/test",
      "destination": "/api/test"
    },
    {
      "source": "/api/firebase-test",
      "destination": "/api/firebase-test"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
