# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_CLOUD_PROJECT: The active Google Cloud / Firebase project ID
GOOGLE_CLOUD_PROJECT=""

# FIREBASE_CLIENT_EMAIL: The client email associated with the service account
FIREBASE_CLIENT_EMAIL=""

# FIREBASE_PRIVATE_KEY: The private key associated with the service account (wrap in quotes to handle linebreaks correctly)
FIREBASE_PRIVATE_KEY=""

# FIRESTORE_DATABASE_ID: Optional specific Firestore custom Database ID (defaults to (default) if omitted)
FIRESTORE_DATABASE_ID=""

